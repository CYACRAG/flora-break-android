<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F6F2">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="18dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="18dp">

            <TextView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:gravity="center"
                android:text="🌱"
                android:textSize="30sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Flora Break"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#117B45"
                android:layout_marginStart="10dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/homeDateText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Montag, 8. Juni 2026"
            android:textSize="14sp"
            android:textColor="#7A7D85"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/homeGreetingText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hallo Lisa 👋"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#111111"
            android:layout_marginBottom="20dp" />

        <!-- Stress Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_soft_card"
            android:padding="18dp"
            android:elevation="3dp"
            android:layout_marginBottom="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stress-Level"
                android:textSize="19sp"
                android:textStyle="bold"
                android:textColor="#111111"
                android:layout_marginBottom="10dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="0dp"
                android:layout_marginBottom="8dp">

                <com.florabreak.app.ui.StressGaugeView
                    android:id="@+id/stressGaugeView"
                    android:layout_width="260dp"
                    android:layout_height="260dp"
                    android:layout_gravity="top|center_horizontal"
                    android:translationY="-36dp" />



                <TextView
                    android:id="@+id/stressScoreText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|center_horizontal"
                    android:layout_marginTop="84dp"
                    android:text="7.6"
                    android:textSize="44sp"
                    android:textStyle="bold"
                    android:textColor="#F06F74" />

                <TextView
                    android:id="@+id/stressLabelText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|center_horizontal"
                    android:layout_marginTop="138dp"
                    android:text="Sehr gestresst"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#F06F74" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|center_horizontal"
                    android:layout_marginTop="164dp"
                    android:text="von 10"
                    android:textSize="13sp"
                    android:textColor="#7D7D7D" />

            </FrameLayout>

            <Button
                android:id="@+id/showBreakButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="🌿  Pause starten  →"
                android:textAllCaps="false"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1E7A43" />
        </LinearLayout>

        <!-- Refresh -->
        <Button
            android:id="@+id/refreshButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="⟳  Daten aktualisieren"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1E7A43"
            android:backgroundTint="#EEF4EE"
            android:layout_marginBottom="26dp" />

        <!-- Letzte Pausen -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Letzte Pausen"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#111111" />

            <TextView
                android:id="@+id/viewAllBreaksText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alle ansehen"
                android:textSize="15sp"
                android:textColor="#1E7A43" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/recentBreakCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_soft_card"
            android:padding="16dp"
            android:elevation="2dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:gravity="center"
                android:text="🌿"
                android:textSize="24sp"
                android:background="@drawable/bg_green_pill" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:id="@+id/recentBreakTitleText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Heute"
                    android:textSize="17sp"
                    android:textColor="#111111"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/recentBreaksText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12 Min · 520 m · Stress -2.8"
                    android:textSize="14sp"
                    android:textColor="#7A7D85"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="›"
                android:textSize="28sp"
                android:textColor="#A0A3AA" />
        </LinearLayout>
        <Space
            android:layout_width="match_parent"
            android:layout_height="42dp" />
        <!-- Bottom Nav -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="92dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_soft_card"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⌂"
                    android:textSize="20sp"
                    android:textColor="#1E7A43" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Home"
                    android:textSize="12sp"
                    android:textColor="#1E7A43" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navHistoryButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↗"
                    android:textSize="20sp"
                    android:textColor="#8A8D96" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Verlauf"
                    android:textSize="12sp"
                    android:textColor="#8A8D96" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navStatsButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▮▮"
                    android:textSize="18sp"
                    android:textColor="#8A8D96" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Statistik"
                    android:textSize="12sp"
                    android:textColor="#8A8D96" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navProfileButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="◠"
                    android:textSize="20sp"
                    android:textColor="#8A8D96" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Profil"
                    android:textSize="12sp"
                    android:textColor="#8A8D96" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
