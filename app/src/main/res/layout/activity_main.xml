<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7F3">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <!-- Oberer Bereich -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🌱  Flora Break"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#1F5E3B" />

            <TextView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="🔔"
                android:textSize="22sp"
                android:background="#E8EFE8" />
        </LinearLayout>

        <!-- Datum und Begrüßung -->
        <TextView
            android:id="@+id/dateText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Montag, 8. Juni 2026"
            android:textSize="14sp"
            android:textColor="#637568"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/greetingText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hallo Lisa 👋"
            android:textSize="25sp"
            android:textStyle="bold"
            android:textColor="#06140C"
            android:layout_marginBottom="22dp" />

        <!-- Stress-Level Karte -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="22dp"
            android:elevation="4dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stress-Level"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#06140C"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/stressLabelText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sehr gestresst"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#E8787E"
                android:layout_marginBottom="8dp" />

            <!-- Vereinfachter Tacho-Ersatz -->
            <TextView
                android:id="@+id/stressScoreText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="7.6"
                android:textSize="52sp"
                android:textStyle="bold"
                android:textColor="#E8787E"
                android:gravity="center"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0        5        10"
                android:textSize="16sp"
                android:textColor="#7A8F80"
                android:gravity="center"
                android:layout_marginBottom="10dp" />

            <ProgressBar
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:progress="76"
                android:max="100"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_marginBottom="22dp" />

            <Button
                android:id="@+id/showBreakButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="🌿  Pause starten  →"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2F6B45" />
        </LinearLayout>

        <!-- Aktualisieren Button bleibt für Java-Code vorhanden -->
        <Button
            android:id="@+id/refreshButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Daten aktualisieren"
            android:textColor="#1F5E3B"
            android:backgroundTint="#E8EFE8"
            android:layout_marginBottom="24dp" />

        <!-- Letzte Pausen Überschrift -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Letzte Pausen"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#06140C" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alle ansehen"
                android:textSize="14sp"
                android:textColor="#1F5E3B" />
        </LinearLayout>

        <TextView
            android:id="@+id/recentBreaksText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Noch keine gespeicherten Pausen"
            android:textSize="14sp"
            android:textColor="#637568"
            android:background="@drawable/bg_soft_card"
            android:padding="16dp"
            android:layout_marginBottom="24dp" />

        <!-- Einfache Bottom Navigation als Mock -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="#FFFFFF"
            android:elevation="6dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="⌂\nHome"
                android:textColor="#1F5E3B"
                android:textSize="12sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="◷\nVerlauf"
                android:textColor="#9AAC9F"
                android:textSize="12sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="▥\nStatistik"
                android:textColor="#9AAC9F"
                android:textSize="12sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="♙\nProfil"
                android:textColor="#9AAC9F"
                android:textSize="12sp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>