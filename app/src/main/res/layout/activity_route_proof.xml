<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_feedback_forest">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="84dp"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingBottom="150dp"
        android:background="#F4F7F3">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_soft_card"
            android:padding="22dp">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:padding="10dp"
                android:src="@drawable/flora_break_logo"
                android:background="@drawable/bg_green_pill"
                android:contentDescription="Flora Break Logo"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Flora Break Foto-Beweis"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#06140C"
                android:gravity="center"
                android:layout_marginBottom="10dp" />

            <ImageView
                android:id="@+id/proofImagePreview"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:scaleType="centerCrop"
                android:background="#EAF3EC"
                android:contentDescription="Streckenbeweis Foto"
                android:layout_marginBottom="18dp" />

            <TextView
                android:id="@+id/proofStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Noch kein Foto-Beweis gespeichert"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#06140C"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/proofPathText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Das Foto wird komprimiert und nur lokal mit deiner Pause verknüpft."
                android:textSize="14sp"
                android:textColor="#637568"
                android:gravity="center" />

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="84dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="18dp"
        android:background="#CC06140C">

        <TextView
            android:id="@+id/backFromProofButton"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:gravity="center"
            android:text="‹"
            android:includeFontPadding="false"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#173522"
            android:background="@drawable/bg_green_pill" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Foto-Beweis"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginStart="14dp" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="28dp"
        android:background="#CC06140C">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fotografiere kurz einen Naturmoment. Der Beweis bleibt lokal auf deinem Gerät."
            android:textSize="14sp"
            android:textColor="#DDEBDE"
            android:gravity="center"
            android:layout_marginBottom="14dp" />

        <Button
            android:id="@+id/captureProofButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="📷  Foto-Beweis aufnehmen"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2F6B45" />

    </LinearLayout>

</FrameLayout>
