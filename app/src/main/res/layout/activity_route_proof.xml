<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#06140C">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="84dp"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingBottom="150dp"
        android:background="#143B22">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#102D1B"
            android:padding="22dp">

            <ImageView
                android:id="@+id/proofImagePreview"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:scaleType="centerCrop"
                android:background="#0B2013"
                android:contentDescription="Streckenbeweis Foto"
                android:layout_marginBottom="18dp" />

            <TextView
                android:id="@+id/proofStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Noch kein Foto aufgenommen"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/proofPathText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Das Foto wird komprimiert und lokal mit der Pause gespeichert."
                android:textSize="14sp"
                android:textColor="#DDEBDE"
                android:gravity="center" />

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="84dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="18dp"
        android:background="#AA06140C">

        <TextView
            android:id="@+id/backFromProofButton"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:gravity="center"
            android:text="‹"
                android:includeFontPadding="false"
                android:padding="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#173522"
            android:background="@drawable/bg_green_pill" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Streckenbeweis"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginStart="14dp" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="28dp"
        android:background="#CC06140C">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fotografiere kurz einen Naturmoment auf deiner Route."
            android:textSize="14sp"
            android:textColor="#DDEBDE"
            android:gravity="center"
            android:layout_marginBottom="14dp" />

        <Button
            android:id="@+id/captureProofButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="📷  Foto aufnehmen"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2F6B45" />

    </LinearLayout>

</FrameLayout>
