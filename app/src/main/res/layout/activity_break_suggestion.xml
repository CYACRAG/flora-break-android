<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7F3">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="18dp">

            <Button
                android:id="@+id/backButton"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:text="←"
                android:textSize="20sp"
                android:textColor="#173522"
                android:backgroundTint="#E8F1EA" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stress erkannt"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#06140C"
                android:layout_marginStart="14dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_soft_card"
            android:padding="22dp"
            android:elevation="4dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Stress-Level"
                android:textSize="19sp"
                android:textStyle="bold"
                android:textColor="#06140C"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/suggestionStressLabelText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sehr gestresst"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#E8787E"
                android:background="@drawable/bg_warning_pill"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:layout_gravity="center"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/suggestionStressScoreText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="8"
                android:textSize="52sp"
                android:textStyle="bold"
                android:textColor="#E8787E"
                android:layout_gravity="center"
                android:layout_marginBottom="-4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="von 10"
                android:textSize="13sp"
                android:textColor="#7A8F80"
                android:layout_gravity="center"
                android:layout_marginBottom="14dp" />

            <FrameLayout
                android:layout_width="240dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:layout_marginBottom="6dp">

                <View
                    android:layout_width="240dp"
                    android:layout_height="10dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_stress_gradient_bar" />

                <View
                    android:id="@+id/stressMarkerView"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="start|center_vertical"
                    android:background="@drawable/bg_stress_marker" />

            </FrameLayout>

            <TextView
                android:layout_width="240dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="0                         5                         10"
                android:textSize="12sp"
                android:textColor="#7A8F80"
                android:gravity="center" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Empfohlene Pausenrouten"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#06140C"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:id="@+id/routeOneCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_route_selected"
            android:padding="18dp"
            android:elevation="4dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:gravity="center"
                android:text="🌳"
                android:textSize="28sp"
                android:background="@drawable/bg_green_pill"
                android:layout_marginEnd="16dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/routeOneNameText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Grünfläche in der Nähe"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#06140C"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/routeOneTypeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Naturroute"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#2F6B45"
                    android:background="@drawable/bg_green_pill"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/routeOneInfoText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="7 Min hin · 14 Min gesamt"
                    android:textSize="14sp"
                    android:textColor="#637568" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/routeTwoCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_soft_card"
            android:padding="18dp"
            android:elevation="3dp"
            android:layout_marginBottom="26dp">

            <TextView
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:gravity="center"
                android:text="🚶"
                android:textSize="26sp"
                android:background="@drawable/bg_warning_pill"
                android:layout_marginEnd="16dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/routeTwoNameText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ruhiger Urban Walk"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#06140C"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/routeTwoTypeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Alternative Route"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#B56A00"
                    android:background="@drawable/bg_warning_pill"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/routeTwoInfoText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Alternative aktive Pause in deiner Nähe"
                    android:textSize="14sp"
                    android:textColor="#637568" />
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/startBreakButton"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:text="🌿  Pause starten"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2F6B45" />

    </LinearLayout>
</ScrollView>
