<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_feedback_forest">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="128dp"
            android:orientation="vertical"
            android:background="#2F6B45"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="22dp"
            android:paddingBottom="14dp">

            <TextView
                android:id="@+id/navigationMainText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Flora Break läuft"
                android:textSize="27sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/navigationSubText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Atme durch und bewege dich bewusst."
                android:textSize="15sp"
                android:textColor="#DCEBDE"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/activeStressText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Stress beim Start: 8/10"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_soft_card"
                android:elevation="5dp"
                android:padding="22dp">

                <TextView
                    android:layout_width="82dp"
                    android:layout_height="82dp"
                    android:gravity="center"
                    android:text="🌲"
                    android:textSize="46sp"
                    android:background="@drawable/bg_green_pill"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:id="@+id/selectedRouteNameText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📍 Ruhige Route"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:textColor="#06140C"
                    android:gravity="center"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Öffne Google Maps für die Navigation. Flora Break begleitet deine Pause im Hintergrund."
                    android:textSize="14sp"
                    android:textColor="#637568"
                    android:gravity="center"
                    android:layout_marginBottom="22dp" />

                <TextView
                    android:id="@+id/proofCameraPlaceholder"
                    android:layout_width="wrap_content"
                    android:layout_height="46dp"
                    android:gravity="center"
                    android:text="📷 Streckenbeweis aufnehmen"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#06140C"
                    android:background="@drawable/bg_green_pill"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp" />
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F4F7F3"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="14dp"
            android:paddingBottom="34dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="78dp"
                android:orientation="horizontal"
                android:paddingBottom="4dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_soft_card"
                    android:elevation="3dp"
                    android:layout_marginEnd="7dp">

                    <TextView
                        android:id="@+id/timerText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="00:00"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="#173522" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pausendauer"
                        android:textSize="12sp"
                        android:textColor="#637568" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_soft_card"
                    android:elevation="3dp"
                    android:layout_marginStart="7dp">

                    <TextView
                        android:id="@+id/remainingTimeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="14 Min"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#173522" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gesamtweg"
                        android:textSize="12sp"
                        android:textColor="#637568" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_soft_card"
                android:elevation="3dp"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:gravity="center"
                    android:text="🌿"
                    android:textSize="20sp"
                    android:background="@drawable/bg_green_pill"
                    android:layout_marginEnd="14dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Pausenstatus"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#06140C" />

                <TextView
                    android:id="@+id/distanceText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Aktiv"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#2F6B45" />
            </LinearLayout>

            <Button
                android:id="@+id/openMapsButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="🗺️  Route in Google Maps öffnen"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#2F6B45"
                android:backgroundTint="#EEF4EE"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/finishBreakButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="■  Pause beenden"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2F6B45" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
